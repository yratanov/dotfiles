#!/bin/bash

set -euo pipefail

NOTIFIED_FILE="/tmp/notified_prs"

touch "$NOTIFIED_FILE"

# Read PR JSON from stdin (passed by check-gh-review-requests)
prs=$(cat)

mapfile -t pr_lines < <(echo "$prs" | jq -c '.[]')

current_numbers=()

for pr_json in "${pr_lines[@]}"; do
  number=$(jq -r .number <<< "$pr_json")
  title=$(jq -r .title <<< "$pr_json")
  url=$(jq -r .url <<< "$pr_json")
  current_numbers+=("$number")

  if grep -qx "$number" "$NOTIFIED_FILE"; then
    continue
  fi

  gdbus call --session \
    --dest org.freedesktop.Notifications \
    --object-path /org/freedesktop/Notifications \
    --method org.freedesktop.Notifications.Notify \
    "" 0 "$HOME/.bin/assets/gh.svg" \
    "New PR Review Request" "$title" \
    '["open", "Open PR"]' '{}' 5000 > /dev/null

  # Listen for action in background
  (
    dbus-monitor --session "interface='org.freedesktop.Notifications',member='ActionInvoked'" 2>/dev/null |
    while read -r line; do
      if echo "$line" | grep -q '"open"'; then
        xdg-open "$url" &
        break
      fi
    done
  ) &
  disown

  echo "$number" >> "$NOTIFIED_FILE"
done

# Clean up notified PRs that are no longer in the review list
if [ ${#current_numbers[@]} -gt 0 ]; then
  printf '%s\n' "${current_numbers[@]}" | sort > /tmp/notified_prs_current
  sort "$NOTIFIED_FILE" | comm -12 - /tmp/notified_prs_current > /tmp/notified_prs_new
  mv /tmp/notified_prs_new "$NOTIFIED_FILE"
  rm -f /tmp/notified_prs_current
else
  > "$NOTIFIED_FILE"
fi
