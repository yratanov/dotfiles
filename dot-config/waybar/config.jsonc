{
  "height": 30, // Waybar height (to be removed for auto height)
  "spacing": 4, // Gaps between modules (4px)
  "modules-left": [
    "hyprland/workspaces",
    "custom/media",
    "custom/satchel-vpn",
    "custom/satchel-prs",
  ],
  "modules-center": ["custom/weather", "clock", "custom/caffeine"],
  "modules-right": [
    "pulseaudio",
    "custom/mouse-battery",
    "network",
    "power-profiles-daemon",
    "cpu",
    "memory",
    "temperature",
    //"bluetooth",
    "hyprland/language",
    "battery",
    "custom/notification",
    "tray",
    "custom/power",
  ],
  // Modules configuration
  "hyprland/workspaces": {
    "format": "{icon} {windows}",
    "on-scroll-up": "hyprctl dispatch workspace e+1",
    "on-scroll-down": "hyprctl dispatch workspace e-1",
    "on-click": "activate",
    "window-rewrite-default": "о­ї ",
    "window-rewrite": {
      "class<chrome-youtube.*>": "п…Є ",
      "class<.*youtube_music>": "у°ќљ ",
      "class<com.mitchellh.ghostty>": "оћ• ",
      "class<org.telegram.desktop>": "о€— ",
      "class<TelegramDesktop>": "о€— ",
      "class<DBeaver>": "оћї ",
      "class<chromium>": "п‰Ё ",
      "class<discord>": "п‡ї ",
      "class<.*geoguessr.*>": "о¬Ѓ ",
      "class<BambuStudio>": "у°ђ« ",
      "class<chrome-chatgpt.com__-Default>": "оЉЊ ",
      "class<chrome-geoguessr.com__-Default>": "оЅ‹ ",
      "class<Slack>": "у°’± ",
      "class<org.mozilla.Thunderbird>": "о¬њ ",
      "class<vlc>": "у°•ј ",
      "class<mpv>": "пЌ® ",
      "class<libreoffice-draw>": "",
      "class<libreoffice-writer>": "ољҐ",
      "class<libreoffice-calc>": "",
      "class<libreoffice-impress>": "",
    },
  },
  "tray": {
    "spacing": 10,
  },
  "clock": {
    "format": "{:%d %b %H:%M}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
    "on-click": "gnome-calendar",
  },
  "bluetooth": {
    "format": "пЉ” {status}",
    "format-disabled": "",
    "format-connected": "пЉ” {num_connections}",
    "tooltip-format": "{controller_alias}\t{controller_address}",
    "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
    "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
    "on-click": "blueberry",
  },
  "cpu": {
    "format": "{usage}% п‹› ",
    "tooltip": false,
    "on-click": "alacritty -e btop",
  },
  "memory": {
    "format": "{}% пѓ‰ ",
    "on-click": "alacritty -e btop",
  },
  "temperature": {
    "critical-threshold": 80,
    "hwmon-path": ["/sys/class/thermal/thermal_zone1/temp"],
    "on-click": "alacritty -e btop",
    "format": "{temperatureC}В°C",
  },
  "custom/hyprlayout": {
    "exec": "~/.config/waybar/scripts/hyprlayout.sh",
    "interval": 2,
    "format": "{}",
  },
  "battery": {
    "states": {
      // "good": 95,
      "warning": 30,
      "critical": 15,
    },
    "format": "{capacity}% {icon}",
    "format-full": "{capacity}% {icon}",
    "format-charging": "{capacity}% п—§",
    "format-plugged": "{capacity}% п‡¦",
    "format-alt": "{time} {icon}",
    "format-icons": ["п‰„ ", "п‰ѓ ", "п‰‚ ", "п‰Ѓ ", "п‰Ђ "],
  },
  "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "пѓ§",
      "performance": "пѓ§",
      "balanced": "п‰Ћ",
      "power-saver": "пЃ¬",
    },
  },
  "network": {
    "format-wifi": "п‡« ({signalStrength}%)",
    "format-ethernet": "{ipaddr}/{cidr} пћ–",
    "tooltip-format": "{essid} {signalStrength}% {ifname} via {gwaddr} пћ–",
    "format-linked": "{ifname} (No IP) пћ–",
    "format-disconnected": "Disconnected вљ ",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
  },
  "pulseaudio": {
    "scroll-step": 10,
    "format": "{volume}% {icon} {format_source}",
    "tooltip-format": "{volume}% {icon} {format_source}",
    "format-bluetooth": "{volume}% {icon}пЉ” {format_source}",
    "format-bluetooth-muted": "пљ© {icon}пЉ” {format_source}",
    "format-muted": "пљ©  {format_source}",
    "format-source": "",
    "format-source-muted": "",
    "format-icons": {
      "headphone": "пЂҐ ",
      "hands-free": "п–ђ",
      "headset": "п–ђ",
      "phone": "п‚•",
      "portable": "п‚•",
      "car": "п†№ ",
      "default": ["пЂ¦", "пЂ§ ", "пЂЁ "],
    },
    "on-click": "pavucontrol",
  },
  "custom/weather": {
    "format": "{}",
    "tooltip": true,
    "interval": 3600,
    "exec": "$HOME/.bin/waybar-weather London",
    "return-type": "json",
    "on-click": "gnome-weather",
  },
  "custom/media": {
    "format": "{icon} {text}",
    "return-type": "json",
    "max-length": 40,
    "format-icons": {
      "spotify": "п†ј",
      "default": "рџЋњ",
    },
    "escape": true,
    "exec": "$HOME/.config/waybar/mediaplayer.py 2> /dev/null", // Script in resources folder
    // "exec": "$HOME/.config/waybar/mediaplayer.py --player spotify 2> /dev/null" // Filter player based on name
  },
  "custom/caffeine": {
    "exec": "~/.bin/caffeine-status",
    "interval": 1,
    "signal": 8,
    "return-type": "json",
    "format": "{}",
    "on-click": "~/.bin/caffeine",
    "tooltip": true
  },
  "custom/power": {
    "format": "вЏ» ",
    "tooltip": false,
    "on-click": "rofi -show p -modi p:rofi-power-menu",
  },
  "custom/satchel-vpn": {
    "name": "vpn",
    "exec": "~/.bin/check_service.sh openvpn-client@satchelcloud SatchelVPN",
    "interval": 10,
    "return-type": "json",
    "format": "{}",
    "tooltip": false,
    "on-click": "~/.bin/toggle_service.sh openvpn-client@satchelcloud",
  },
  "custom/satchel-prs": {
    "exec": "~/.bin/check-gh-review-requests mysencare/pulse-app",
    "interval": 60,
    "return-type": "json",
    "on-click": "xdg-open https://github.com/mysencare/pulse-app/pulls?q=is%3Apr+is%3Aopen+user-review-requested%3A%40me && hyprctl dispatch workspace 1",
  },
  "custom/mouse-battery": {
    "exec": "solaar show 2>/dev/null | grep -i 'Battery:' | head -n1 | awk '{print $2}'",
    "interval": 60,
    "format": "оѕє ({})",
  },
  "hyprland/language": {
    "format": "{}",
    "keyboard-name": "keychron-keychron-q2-pro-keyboard",
    "format-en": "EN",
    "format-ru": "RU",
  },
  "custom/notification": {
    "tooltip": false,
    "format": "{icon}",
    "format-icons": {
      "notification": "у±…«",
      "none": "у°‚љ",
      "dnd-notification": "у°‚›",
      "dnd-none": "у°‚›",
    },
    "return-type": "json",
    "exec": "swaync-client -swb",
    "on-click": "swaync-client -t -sw",
    "on-click-right": "swaync-client -d -sw",
    "escape": true,
  },
}
